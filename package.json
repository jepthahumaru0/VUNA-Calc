{
  "name": "vuna-calc",
  "version": "1.0.0",
  "description": "VUNA Calculator - SEN 482 CI/CD CA",
  "main": "src/calculator.js",
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint .",
    "build": "node scripts/build.mjs"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/calculator.js"],
    "coverageThreshold": {
